# -----------------------------------------------------------------------------
# CeleCircle production environment template
# Copy this file to .env.production and fill with real secret values.
# -----------------------------------------------------------------------------

# Core app security
SECRET_KEY=replace_with_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
INTERNAL_SERVICE_TOKEN=replace_with_internal_shared_secret

# Database
POSTGRES_USER=celecircle
POSTGRES_PASSWORD=replace_with_strong_db_password
POSTGRES_DB=celecircle
DATABASE_URL=postgresql://celecircle:replace_with_strong_db_password@postgres:5432/celecircle

# Cache / rate-limiting backend
REDIS_URL=redis://redis:6379/0

# API Gateway operational settings
RATE_LIMIT_PER_MINUTE=100
DOWNSTREAM_TIMEOUT_SECONDS=5
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN_SECONDS=30

# External integrations
GNEWS_API_KEY=replace_with_real_key
USE_MOCK_PAYMENTS=false
STRIPE_SECRET_KEY=replace_with_real_stripe_secret

# Optional domain/TLS metadata for ops
APP_DOMAIN=api.yourdomain.com
TLS_CERT_PATH=/etc/nginx/certs/fullchain.pem
TLS_KEY_PATH=/etc/nginx/certs/privkey.pem
